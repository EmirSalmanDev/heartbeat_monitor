{
  "name": "sentinel",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev:api": "pnpm --filter @sentinel/api dev",
    "dev:worker": "pnpm --filter @sentinel/worker dev",
    "dev:web": "pnpm --filter @sentinel/web dev",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @sentinel/db generate",
    "db:migrate": "pnpm --filter @sentinel/db migrate:dev",
    "db:studio": "pnpm --filter @sentinel/db studio"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
